{
  "env": {
    "LLD_HOOK_MODE": "warn"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/Prasad_1/Projects/hitl-dev-platform && bash ai/claude/hooks/check-hitl-context.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/Prasad_1/Projects/hitl-dev-platform && bash ai/claude/hooks/check-domain-boundary.sh"
          },
          {
            "type": "command",
            "command": "cd /Users/Prasad_1/Projects/hitl-dev-platform && bash ai/claude/hooks/rebuild-graph.sh"
          },
          {
            "type": "command",
            "command": "cd /Users/Prasad_1/Projects/hitl-dev-platform && bash ai/claude/hooks/sync-step-to-issue.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/Prasad_1/Projects/hitl-dev-platform && bash ai/claude/hooks/write-session-summary.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(git merge-base *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(pytest *)",
      "Bash(ruff check *)",
      "Bash(semgrep *)",
      "Bash(python3 *)",
      "Bash(find docs/*)",
      "Bash(find ai/*)",
      "Bash(cat docs/*)",
      "Bash(cat ai/*)"
    ]
  }
}
