{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ai/claude/hooks/check-hitl-context.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ai/claude/hooks/check-domain-boundary.sh"
          },
          {
            "type": "command",
            "command": "bash ai/claude/hooks/rebuild-graph.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ai/claude/hooks/write-session-summary.sh"
          }
        ]
      }
    ]
  }
}
