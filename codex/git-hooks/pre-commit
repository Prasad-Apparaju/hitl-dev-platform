#!/usr/bin/env bash
# pre-commit: verify HITL context before source code commits.
#
# Default mode: blocks missing/incomplete context; warns on status and boundary issues.
# Strict mode:  also blocks Tier 2+ commits without implementation-approved status
#               and blocks boundary violations.
# Enable strict mode: set HITL_STRICT=1 in the environment or git config.
#
#   git config hitl.strict true   (project-level)
#   HITL_STRICT=1 git commit ...  (one-off)

set -euo pipefail

# Resolve strict mode from env or git config
STRICT=false
if [[ "${HITL_STRICT:-}" == "1" ]] || git config --bool hitl.strict 2>/dev/null | grep -q "true"; then
  STRICT=true
fi

STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || echo "")

if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

# Check if any staged files are source code
SOURCE_STAGED=false
while IFS= read -r file; do
  case "$file" in
    *.py|*.ts|*.js|*.tsx|*.jsx|*.go|*.java|*.rb|*.rs|*.cpp|*.c|*.h)
      SOURCE_STAGED=true
      break
      ;;
  esac
done <<< "$STAGED_FILES"

if [[ "$SOURCE_STAGED" == "false" ]]; then
  exit 0
fi

CONTEXT_FILE=".hitl/current-change.yaml"
if [[ ! -f "$CONTEXT_FILE" ]]; then
  echo "" >&2
  echo "HITL CONTEXT MISSING: No .hitl/current-change.yaml found." >&2
  echo "" >&2
  echo "Before committing source code, initialize the change context:" >&2
  echo "  codex 'Initialize the HITL change context for: [your change description]'" >&2
  echo "" >&2
  echo "See AGENTS.md § Change Initialization for required fields." >&2
  echo "" >&2
  exit 1
fi

# Verify required fields are present
REQUIRED_FIELDS=("change_id" "tier" "status" "manifest")
for field in "${REQUIRED_FIELDS[@]}"; do
  if ! grep -q "^${field}:" "$CONTEXT_FILE" 2>/dev/null; then
    echo "HITL CONTEXT INCOMPLETE: .hitl/current-change.yaml is missing required field: ${field}" >&2
    echo "Re-run the Change Initialization workflow to regenerate the context file." >&2
    exit 1
  fi
done

TIER=$(grep "^tier:" "$CONTEXT_FILE" | awk '{print $2}' | tr -d '"' || echo "0")
STATUS=$(grep "^status:" "$CONTEXT_FILE" | awk '{print $2}' | tr -d '"' || echo "unknown")
CHANGE_ID=$(grep "^change_id:" "$CONTEXT_FILE" | awk '{print $2}' | tr -d '"' || echo "unknown")

# Status gate
APPROVED_STATUSES=("implementation-approved" "conformance-review-pending" "review-complete" "pr-ready")
STATUS_APPROVED=false
for s in "${APPROVED_STATUSES[@]}"; do
  [[ "$STATUS" == "$s" ]] && STATUS_APPROVED=true && break
done

if [[ "$STATUS_APPROVED" == "false" ]]; then
  if [[ "$STRICT" == "true" && "$TIER" -ge 2 ]]; then
    echo "" >&2
    echo "HITL BLOCKED (strict mode): Change $CHANGE_ID is Tier $TIER with status '$STATUS'." >&2
    echo "Tier 2+ source commits require status: implementation-approved or later." >&2
    echo "Get architecture approval or set HITL_STRICT=0 to commit in warn-only mode." >&2
    echo "" >&2
    exit 1
  else
    echo "HITL WARNING: Change status is '${STATUS}' — design approval is still pending." >&2
    if [[ "$TIER" -ge 2 ]]; then
      echo "  Tier $TIER change: ensure LLD is approved before requesting code review." >&2
      echo "  Enable strict mode (HITL_STRICT=1 or git config hitl.strict true) to block at this point." >&2
    fi
  fi
fi

# LLD existence check for Tier 2+ (strict mode)
if [[ "$STRICT" == "true" && "$TIER" -ge 2 ]]; then
  LLD_PATH=$(grep "^  lld:" "$CONTEXT_FILE" | awk '{print $2}' | tr -d '"' || echo "")
  if [[ -n "$LLD_PATH" && "$LLD_PATH" != "pending" && ! -f "$LLD_PATH" ]]; then
    echo "" >&2
    echo "HITL BLOCKED (strict mode): LLD not found at '$LLD_PATH'." >&2
    echo "Create or approve the LLD before committing Tier $TIER source code." >&2
    echo "" >&2
    exit 1
  fi
fi

# Domain boundary check
ALLOWED_PATHS=$(python3 - << 'PYEOF' 2>/dev/null || echo ""
import sys, re

try:
    import yaml
    with open(".hitl/current-change.yaml") as f:
        data = yaml.safe_load(f)
    paths = data.get("allowed_paths", [])
    print("\n".join(paths))
except ImportError:
    in_block = False
    with open(".hitl/current-change.yaml") as f:
        for line in f:
            if line.startswith("allowed_paths:"):
                in_block = True
                continue
            if in_block:
                m = re.match(r"^\s+-\s+(.+)", line)
                if m:
                    print(m.group(1).strip())
                elif line and not line[0].isspace():
                    break
except Exception:
    pass
PYEOF
)

if [[ -n "$ALLOWED_PATHS" ]]; then
  BOUNDARY_VIOLATIONS=()
  while IFS= read -r file; do
    case "$file" in
      *.py|*.ts|*.js|*.tsx|*.jsx|*.go|*.java|*.rb|*.rs|*.cpp|*.c|*.h) ;;
      *) continue ;;
    esac
    MATCHED=false
    while IFS= read -r pattern; do
      [[ -z "$pattern" ]] && continue
      case "$file" in
        $pattern) MATCHED=true; break ;;
      esac
      PATTERN_DIR="${pattern%%\**}"
      if [[ "$file" == "$PATTERN_DIR"* ]]; then
        MATCHED=true
        break
      fi
    done <<< "$ALLOWED_PATHS"
    if [[ "$MATCHED" == "false" ]]; then
      BOUNDARY_VIOLATIONS+=("$file")
    fi
  done <<< "$STAGED_FILES"

  if [[ ${#BOUNDARY_VIOLATIONS[@]} -gt 0 ]]; then
    echo "" >&2
    echo "HITL DOMAIN BOUNDARY (change: $CHANGE_ID):" >&2
    for f in "${BOUNDARY_VIOLATIONS[@]}"; do
      echo "  $f is outside allowed_paths" >&2
    done
    echo "" >&2
    if [[ "$STRICT" == "true" ]]; then
      echo "BLOCKED (strict mode): update allowed_paths in .hitl/current-change.yaml" >&2
      echo "and confirm the domain boundary expansion with the architect." >&2
      echo "" >&2
      exit 1
    else
      echo "If intentional, update allowed_paths in .hitl/current-change.yaml" >&2
      echo "and confirm with the architect. Enable strict mode (HITL_STRICT=1) to block." >&2
      echo "" >&2
    fi
  fi
fi

exit 0
